# Hushpot Desk — frontend environment

# Address of the deployed Hushpot contract on Sepolia (required).
# Take this from the hardhat-deploy output: `npx hardhat deploy --network sepolia`.
VITE_HUSHPOT_ADDRESS=

# Address of the confidential USDT (ERC-7984) token used by the circle.
# Defaults to the Sepolia cUSDT wrapper if left blank; set this only if you
# deployed your own token.
VITE_CUSDT_ADDRESS=0x4E7B06D78965594eB5EF5414c357ca21E1554491
